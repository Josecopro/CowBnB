# ============================================================
# CowBnB – Variables de entorno
# Copiar a .env y completar con valores reales.
# NUNCA commitear .env al repositorio.
# ============================================================

# --- Firebase ---
FIREBASE_PROJECT_ID=cowbnb-prod
FIREBASE_STORAGE_BUCKET=cowbnb-prod.appspot.com

# --- Bold Pagos (Colombia) ---
BOLD_SECRET_KEY=your_bold_secret_key_here
BOLD_API_KEY=your_bold_api_key_here
BOLD_WEBHOOK_SECRET=your_bold_webhook_secret_here
BOLD_CHECKOUT_BASE_URL=https://checkout.bold.co

# --- Copernicus Data Space (NDVI) ---
COPERNICUS_CLIENT_ID=your_copernicus_client_id
COPERNICUS_CLIENT_SECRET=your_copernicus_client_secret
COPERNICUS_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
COPERNICUS_STAC_URL=https://catalogue.dataspace.copernicus.eu/odata/v1

# --- NDVI Configuración ---
NDVI_THRESHOLD=0.3
NDVI_JOB_INTERVAL_HOURS=6
NDVI_ACTION_TOKEN_TTL_HOURS=48

# --- Email (SendGrid o SMTP) ---
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your_sendgrid_key_here
EMAIL_FROM=noreply@cowbnb.co
APP_BASE_URL=https://cowbnb.co

# --- Entorno ---
NODE_ENV=production
LOG_LEVEL=info
