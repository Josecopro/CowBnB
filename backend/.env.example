# CowBnB Backend - Example Environment Variables

# Firebase Project
FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase Admin SDK Service Account (JSON string, only for local/dev)
# You can generate this from Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-firebase-project-id",...}

# (Optional) Other environment variables
# NODE_ENV=development
# LOG_LEVEL=info
# Add more as needed for your setup
