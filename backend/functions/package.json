{
  "name": "cowbnb-functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "18"
  },
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && npx -y firebase-tools@latest emulators:start --only functions",
    "shell": "npm run build && npx -y firebase-tools@latest functions:shell",
    "start": "npm run shell",
    "deploy": "npx -y firebase-tools@latest deploy --only functions",
    "logs": "npx -y firebase-tools@latest functions:log"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.5.0",
    "firebase-functions": "^5.1.0",
    "helmet": "^7.1.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.12"
  }
}
