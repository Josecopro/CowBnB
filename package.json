{
  "name": "cowbnb-backend",
  "version": "1.0.0",
  "description": "CowBnB – Backend Firebase Functions (Node 18)",
  "main": "backend/functions/index.js",
  "engines": {
    "node": "18"
  },
  "scripts": {
    "serve": "firebase emulators:start --only functions,firestore,storage,auth",
    "deploy": "firebase deploy --only functions",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:indexes": "firebase deploy --only firestore:indexes",
    "lint": "eslint backend/",
    "test": "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "ngeohash": "^0.6.3",
    "axios": "^1.6.5",
    "crypto": "^1.0.1",
    "uuid": "^9.0.0",
    "joi": "^17.11.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.8"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.3",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "firebase-functions-test": "^3.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFilesAfterFramework": []
  }
}
